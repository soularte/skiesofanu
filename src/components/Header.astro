---
interface Props {
  siteName: string;
  siteTagline?: string;
}

const { siteName, siteTagline } = Astro.props;

const navLinks = [
  { href: '/', label: 'Главная' },
  { href: '/books', label: 'Книги' },
  { href: '/about', label: 'Об авторах' },
];

const currentPath = Astro.url.pathname;
---
<header class="border-b border-dp-border bg-parchment/90 backdrop-blur-sm sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 pt-4 pb-[26px] flex items-center justify-between">
    <a href="/" class="flex flex-col leading-tight hover:text-dp-gold transition-colors group">
      <span class="font-heading text-2xl font-semibold tracking-wide text-dp-text group-hover:text-dp-gold transition-colors">{siteName}</span>
      {siteTagline && <span class="text-[10px] tracking-widest uppercase text-dp-muted mt-0.5">{siteTagline}</span>}
    </a>
    <nav class="hidden md:flex items-center gap-8">
      {navLinks.map(link => (
        <a
          href={link.href}
          class={`text-sm tracking-widest uppercase transition-colors ${
            currentPath === link.href
              ? 'text-dp-gold border-b border-dp-gold pb-0.5'
              : 'text-dp-muted hover:text-dp-text'
          }`}
        >
          {link.label}
        </a>
      ))}
    </nav>
    <!-- Mobile menu button -->
    <button id="menu-toggle" class="md:hidden text-dp-muted hover:text-dp-text" aria-label="Открыть меню">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-dp-border">
    <nav class="max-w-5xl mx-auto px-6 py-4 flex flex-col gap-4">
      {navLinks.map(link => (
        <a href={link.href} class="text-sm tracking-widest uppercase text-dp-muted hover:text-dp-text transition-colors">
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
