---
interface Props {
  copyright: string;
}
const { copyright } = Astro.props;
---
<footer class="border-t border-dp-border mt-20">
  <div class="max-w-5xl mx-auto px-6 py-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <span class="font-heading text-dp-muted text-sm">© {new Date().getFullYear()} {copyright}</span>
    <nav class="flex gap-6">
      <a href="/" class="text-xs tracking-widest uppercase text-dp-muted hover:text-dp-text transition-colors">Главная</a>
      <a href="/books" class="text-xs tracking-widest uppercase text-dp-muted hover:text-dp-text transition-colors">Книги</a>
      <a href="/about" class="text-xs tracking-widest uppercase text-dp-muted hover:text-dp-text transition-colors">Об авторах</a>
    </nav>
  </div>
</footer>
