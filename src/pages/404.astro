---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Страница не найдена" description="Такой страницы не существует.">
  <div class="max-w-5xl mx-auto px-6 pt-32 pb-24 text-center">
    <p class="font-heading text-8xl font-semibold text-dp-gold/30 mb-4">404</p>
    <div class="w-12 h-px bg-dp-gold mx-auto mb-8"></div>
    <h1 class="font-heading text-2xl font-semibold mb-4">Такой страницы не существует</h1>
    <p class="text-dp-muted text-sm mb-12 leading-relaxed">
      Возможно, адрес изменился или страница была удалена.
    </p>
    <nav class="flex flex-wrap justify-center gap-4">
      <a href="/" class="text-xs tracking-widest uppercase px-4 py-2 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors">
        Главная
      </a>
      <a href="/books" class="text-xs tracking-widest uppercase px-4 py-2 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
        Книги
      </a>
      <a href="/about" class="text-xs tracking-widest uppercase px-4 py-2 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
        Об авторах
      </a>
    </nav>
  </div>
</BaseLayout>
