---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CharactersGallery from '../../components/CharactersGallery.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const books = await getCollection('books');
  return books.map(book => ({
    params: { slug: book.slug },
    props: { book },
  }));
}

const { book } = Astro.props;
const { Content } = await render(book);
const isSeries = !!(book.data.books && book.data.books.length > 0);
const coverLinks = book.data.links?.length ? book.data.links : (book.data.seriesLinks ?? []);
---
<BaseLayout title={book.data.title} description={book.data.logline ?? book.data.title}>
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-16">

    <!-- Breadcrumb -->
    <nav class="mb-10 text-xs tracking-widest uppercase text-dp-muted">
      <a href="/books" class="hover:text-dp-gold transition-colors">Книги</a>
      <span class="mx-2">→</span>
      <span class="text-dp-text">{book.data.title}</span>
    </nav>

    <!-- Series title above grid -->
    {book.data.series && (
      <div class="text-center mb-16">
        <h1 class="font-heading text-4xl md:text-5xl font-semibold text-dp-gold">{book.data.series}</h1>
        <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      </div>
    )}

    <!-- Main grid: cover | info -->
    <div class="grid grid-cols-1 md:grid-cols-[220px_1fr] gap-12 items-start">

      <!-- Left: cover + purchase links -->
      <div class="flex flex-col items-center md:items-start gap-6">
        <div class="relative">
          <img
            src={`/images/${book.data.cover}`}
            alt={book.data.title}
            class="w-[200px] shadow-lg"
          />
          <div class="absolute -bottom-2 -right-2 w-full h-full border border-dp-gold/30 pointer-events-none"></div>
        </div>

        {coverLinks.length > 0 && (
          <div class="flex flex-col gap-1.5 w-[200px]">
            {book.data.marketplace && (
              <span class="self-start text-[10px] font-body tracking-widest px-1.5 py-0.5 bg-dp-border/40 text-dp-muted border border-dp-border cursor-default select-none">
                Маркетплейсы
              </span>
            )}
            <div class="flex flex-wrap gap-1">
              {coverLinks.map(link => (
                <a
                  href={link.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-[10px] font-body tracking-widest px-1.5 py-0.5 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors"
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Right: title, genres, description -->
      <div>
        <h1 class="font-heading text-4xl md:text-5xl font-semibold leading-tight mb-4">{book.data.title}</h1>
        <div class="w-12 h-px bg-dp-gold mb-6"></div>

        {book.data.genres && (
          <div class="flex flex-wrap gap-2 mb-6">
            {book.data.genres.map(g => (
              <span class="text-[10px] tracking-widest uppercase px-2 py-1 border border-dp-border text-dp-muted">{g}</span>
            ))}
          </div>
        )}

        {book.data.logline && (
          <p class="font-accent italic text-dp-gold/80 text-base mb-6 leading-relaxed">{book.data.logline}</p>
        )}

        <div class="prose prose-sm prose-invert max-w-none text-dp-text leading-relaxed">
          <Content />
        </div>
      </div>
    </div>

    <!-- Series description + Reading order -->
    {(book.data.seriesDescription || (book.data.readingOrder && book.data.readingOrder.length > 0)) && book.data.series && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-dp-border"></div>
          <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
          <div class="flex-1 h-px bg-dp-border"></div>
        </div>
        <h2 class="font-heading text-2xl font-semibold mb-4">О цикле «{book.data.series}»</h2>
        {book.data.seriesDescription && (
          <div class="max-w-2xl mb-4 space-y-4">
            {book.data.seriesDescription.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
              <p class="text-dp-text leading-relaxed">{para.trim()}</p>
            ))}
          </div>
        )}
        {book.data.seriesLinks && book.data.seriesLinks.length > 0 && (
          <div class="flex flex-wrap items-baseline gap-2 mb-8">
            <span class="text-xs tracking-widest uppercase text-dp-muted shrink-0">Читать на литплощадках:</span>
            {book.data.seriesLinks.map(link => (
              <a href={link.url} target="_blank" rel="noopener noreferrer"
                class="text-[10px] font-body tracking-widest px-1.5 py-0.5 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        )}
        {book.data.readingOrder && book.data.readingOrder.length > 0 && (
          <div>
            <h3 class="font-heading text-lg font-semibold mb-4 text-dp-text">Порядок чтения</h3>
            <div class="max-w-2xl">
              <ol class="space-y-3">
                {book.data.readingOrder.map((item, i) => (
                  <li class="flex gap-3 text-dp-text items-baseline">
                    <span class="text-dp-gold/60 leading-tight w-5 shrink-0">{i + 1}</span>
                    <span class="flex flex-wrap items-baseline gap-1.5">
                      <span>{item.title}</span>
                      {item.labels && item.labels.map(label => (
                        <span class="text-[9px] tracking-widest uppercase px-1.5 py-0.5 border border-dp-border text-dp-muted">{label}</span>
                      ))}
                    </span>
                  </li>
                ))}
              </ol>
            </div>
            {book.data.readingMap && (
              <div class="mt-6">
                <a
                  href={book.data.readingMap.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-xs tracking-widest uppercase px-3 py-1.5 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors"
                >{book.data.readingMap.label}</a>
              </div>
            )}
          </div>
        )}
      </div>
    )}

    <!-- Booktrailer section -->
    {book.data.booktrailer && book.data.booktrailer.visible !== false && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-dp-border"></div>
          <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
          <div class="flex-1 h-px bg-dp-border"></div>
        </div>
        <h2 class="font-heading text-2xl font-semibold mb-6 text-center">Буктрейлер</h2>
        <div class="flex justify-center">
          <div class={book.data.booktrailer.orientation === 'vertical' ? 'max-h-[600px] w-auto max-w-xs' : 'w-full max-w-2xl'}>
            <video
              src={`/videos/${book.data.booktrailer.file}`}
              controls
              class="w-full block"
              style="background:#1A1A2E;"
            />
          </div>
        </div>
      </div>
    )}

    <!-- Books in series -->
    {isSeries && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-dp-border"></div>
          <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
          <div class="flex-1 h-px bg-dp-border"></div>
        </div>
        <h2 class="font-heading text-2xl font-semibold mb-8">Книги цикла</h2>
        <div class="space-y-10">
          {(book.data.books ?? []).slice(1).map((b, i) => (
            <article class={`flex flex-col items-center sm:items-start sm:flex-row gap-8 ${i % 2 === 1 ? 'sm:flex-row-reverse' : ''}`}>
              <!-- Cover + links -->
              <div class={`flex-shrink-0 flex flex-col gap-4 items-center sm:items-start ${i % 2 === 1 ? 'sm:items-end' : ''}`}>
                <img src={`/images/${b.cover}`} alt={b.title} class="w-[200px] shadow-lg" />
                {b.links && b.links.length > 0 && (
                  <div class="flex flex-col gap-1.5 w-[200px] items-center sm:items-start">
                    {b.marketplace && (
                      <span class={`text-[10px] font-body tracking-widest px-1.5 py-0.5 bg-dp-border/40 text-dp-muted border border-dp-border cursor-default select-none sm:${i % 2 === 1 ? 'self-end' : 'self-start'}`}>
                        МАРКЕТПЛЕЙСЫ
                      </span>
                    )}
                    <div class={`flex flex-wrap gap-1 justify-center sm:justify-start ${i % 2 === 1 ? 'sm:justify-end' : ''}`}>
                      {b.links.map(link => (
                        <a href={link.url} target="_blank" rel="noopener noreferrer"
                          class="text-[10px] font-body tracking-widest px-1.5 py-0.5 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors">
                          {link.label}
                        </a>
                      ))}
                    </div>
                  </div>
                )}
              </div>
              <!-- Info -->
              <div class="flex-1">
                <h3 class="font-heading text-2xl md:text-3xl font-semibold mb-2">{b.title}</h3>
                <div class="w-8 h-px bg-dp-gold mb-4"></div>
                {b.genres && b.genres.length > 0 && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {b.genres.map((g: string) => (
                      <span class="text-[10px] tracking-widest uppercase px-2 py-1 border border-dp-border text-dp-muted">{g}</span>
                    ))}
                  </div>
                )}
                {b.description && (
                  <div class="space-y-3">
                    {b.description.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                      <p class="text-dp-text leading-relaxed">{para.trim()}</p>
                    ))}
                  </div>
                )}
              </div>
            </article>
          ))}
        </div>
      </div>
    )}

    <!-- Characters section -->
    {book.data.characters && book.data.characters.length > 0 && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-dp-border"></div>
          <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
          <div class="flex-1 h-px bg-dp-border"></div>
        </div>
        <h2 class="font-heading text-2xl font-semibold mb-6">Персонажи</h2>
        <CharactersGallery characters={book.data.characters} folder={book.data.charactersFolder} />
        {book.data.characterMaps && book.data.characterMaps.length > 0 && (
          <div class="flex flex-wrap gap-3 mt-6">
            {book.data.characterMaps.map(m => (
              <a href={m.url} target="_blank" rel="noopener noreferrer"
                class="text-xs tracking-widest uppercase px-3 py-1.5 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
                {m.label}
              </a>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- World section -->
    {book.data.world && (
      <div class="mt-16">
        <div class="flex items-center gap-4 mb-6">
          <div class="flex-1 h-px bg-dp-border"></div>
          <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
          <div class="flex-1 h-px bg-dp-border"></div>
        </div>
        <h2 class="font-heading text-2xl font-semibold mb-4">Мир</h2>
        <div class="mb-4 space-y-4">
          {book.data.world.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
            <p class="text-dp-text leading-relaxed">{para.trim()}</p>
          ))}
        </div>
        {book.data.worldMaps && book.data.worldMaps.length > 0 && (
          <div class="flex flex-wrap gap-3">
            {book.data.worldMaps.map(m => (
              <a href={m.url} target="_blank" rel="noopener noreferrer"
                class="text-xs tracking-widest uppercase px-3 py-1.5 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
                {m.label}
              </a>
            ))}
          </div>
        )}
      </div>
    )}

  </div>
</BaseLayout>
