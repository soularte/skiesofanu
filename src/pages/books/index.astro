---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import bookOrder from '../../data/book-order.json';

const allBooks = await getCollection('books');

// Только книги без серии или первые в серии
const visibleBooks = allBooks.filter(b =>
  !b.data.series || (b.data.books && b.data.books.length > 0)
);

// Сортировка по book-order.json; книги не в списке — в конце
const sorted = [...visibleBooks].sort((a, b) => {
  const ia = (bookOrder as string[]).indexOf(a.slug);
  const ib = (bookOrder as string[]).indexOf(b.slug);
  const ra = ia === -1 ? 999 : ia;
  const rb = ib === -1 ? 999 : ib;
  return ra - rb;
});

// Предрендерим тело каждой книги (только если нет mediumDescription)
const ordered = await Promise.all(
  sorted.map(async book => {
    if (book.data.mediumDescription) return { book, Content: null };
    const { Content } = await render(book);
    return { book, Content };
  })
);
---
<BaseLayout title="Книги" description="Все книги соавторского дуэта.">
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-4">
    <div class="text-center mb-16">
      <h1 class="font-heading text-4xl md:text-5xl font-semibold">Книги</h1>
      <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
    </div>

    <div class="space-y-16">
      {ordered.map(({ book, Content }, i) => (
        <article class={`flex flex-col items-center md:items-start md:flex-row gap-10 ${i % 2 === 1 ? 'md:flex-row-reverse' : ''}`}>
          <!-- Cover -->
          <a href={`/books/${book.slug}`} class="flex-shrink-0 relative group">
            <img
              src={`/images/${book.data.cover}`}
              alt={book.data.title}
              class="w-56 shadow-md group-hover:shadow-lg transition-shadow duration-300"
            />
            <div class="absolute inset-0 bg-white/0 group-hover:bg-white/10 transition-colors duration-300"></div>
          </a>
          <!-- Info -->
          <div class="flex-1">
            <h2 class="font-heading text-2xl md:text-3xl font-semibold mb-2">
              <a href={`/books/${book.slug}`} class="hover:text-dp-gold transition-colors">{book.data.title}</a>
            </h2>
            <!-- Genres -->
            <div class="flex flex-wrap gap-2 mb-3">
              {book.data.genres.map(g => (
                <span class="text-[10px] font-body tracking-widest px-2 py-0.5 border border-dp-border text-dp-muted">{g}</span>
              ))}
            </div>
            <div class="w-8 h-px bg-dp-gold mb-4"></div>
            <div class="mb-6 space-y-3">
              {book.data.mediumDescription
                ? book.data.mediumDescription.split('\n\n').filter((p: string) => p.trim()).map((para: string) => (
                    <p class="text-dp-muted leading-relaxed">{para.trim()}</p>
                  ))
                : Content && <div class="prose prose-sm max-w-none text-dp-muted leading-relaxed [&>p]:mb-3"><Content /></div>
              }
            </div>
            {(book.data.links?.length ? book.data.links : (book.data.seriesLinks ?? [])).length > 0 && (
              <div class="flex flex-wrap gap-2 mb-6">
                {book.data.marketplace && (
                  <span class="text-[10px] font-body tracking-widest px-1.5 py-0.5 bg-dp-border/40 text-dp-muted border border-dp-border cursor-default select-none">
                    МАРКЕТПЛЕЙСЫ
                  </span>
                )}
                {(book.data.links?.length ? book.data.links : (book.data.seriesLinks ?? [])).map(link => (
                  <a
                    href={link.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[10px] font-body tracking-widest px-1.5 py-0.5 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors"
                  >
                    {link.label}
                  </a>
                ))}
              </div>
            )}
            <a href={`/books/${book.slug}`} class="px-5 py-2 bg-dp-gold text-dp-dark text-sm tracking-widest uppercase hover:bg-dp-copper transition-colors inline-block">
              Подробнее
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
