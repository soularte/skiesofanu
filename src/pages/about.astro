---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { readFileSync } from 'fs';
import { join } from 'path';
import matter from 'gray-matter';

const linksRaw = readFileSync(join(process.cwd(), 'src/data/links.md'), 'utf-8');
const { data: links } = matter(linksRaw);

const authorsRaw = readFileSync(join(process.cwd(), 'src/data/authors.md'), 'utf-8');
const { data: authors } = matter(authorsRaw) as { data: {
  bio: string[];
  ksenia: { name: string; photo: string; bioUrl?: string; bioLabel?: string };
  vasily: { name: string; photo: string; bioUrl?: string; bioLabel?: string };
  influences?: string[];
}};

---
<BaseLayout title="Об авторах" description="Об авторском дуэте Ксения Котова и Василий Зеленков — создателях цикла Небеса Ану.">
  <div class="max-w-5xl mx-auto px-6 pt-20 pb-4">
    <!-- Page header -->
    <div class="text-center mb-16">
      <h1 class="font-heading text-4xl md:text-5xl font-semibold">Об авторах</h1>
      <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      <p class="font-accent italic text-dp-gold mt-5 text-base">Фантасты · Мечтатели · Создатели миров</p>
    </div>

    <!-- Authors: photo — bio — photo -->
    <div class="grid grid-cols-1 md:grid-cols-[1fr_2fr_1fr] gap-6 items-start">
      <!-- Ксения -->
      <div class="flex flex-col items-center gap-4 order-1 md:order-1">
        <div class="relative w-48 h-64">
          <img src={`/images/authors/${authors.ksenia.photo}`} alt={authors.ksenia.name} loading="lazy" class="w-48 h-64 object-cover object-top grayscale" />
          <div class="absolute -bottom-2 -right-2 w-full h-full border border-dp-gold/30 pointer-events-none"></div>
        </div>
        <p class="font-heading text-lg font-semibold">{authors.ksenia.name}</p>
        {authors.ksenia.bioUrl && (
          <a href={authors.ksenia.bioUrl} class="text-[10px] tracking-widest uppercase px-2 py-1 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
            {authors.ksenia.bioLabel ?? 'Биография'}
          </a>
        )}
      </div>

      <!-- Bio -->
      <div class="order-3 md:order-2">
        <div class="space-y-4 text-dp-text leading-relaxed">
          {authors.bio.map((p: string) => <p>{p}</p>)}
        </div>
        {authors.influences && authors.influences.length > 0 && (
          <div class="mt-8 pt-6 border-t border-dp-border">
            <h3 class="font-heading text-xs tracking-widest uppercase text-dp-muted mb-3">Влияния и вдохновения</h3>
            <div class="flex flex-wrap gap-2">
              {authors.influences.map((tag: string) => (
                <span class="text-[10px] tracking-widest uppercase px-2 py-1 border border-dp-border text-dp-muted">{tag}</span>
              ))}
            </div>
          </div>
        )}
      </div>

      <!-- Василий -->
      <div class="flex flex-col items-center gap-4 order-2 md:order-3">
        <div class="relative w-48 h-64">
          <img src={`/images/authors/${authors.vasily.photo}`} alt={authors.vasily.name} loading="lazy" class="w-48 h-64 object-cover object-top grayscale" />
          <div class="absolute -bottom-2 -right-2 w-full h-full border border-dp-gold/30 pointer-events-none"></div>
        </div>
        <p class="font-heading text-lg font-semibold">{authors.vasily.name}</p>
        {authors.vasily.bioUrl && (
          <a href={authors.vasily.bioUrl} class="text-[10px] tracking-widest uppercase px-2 py-1 border border-dp-border text-dp-muted hover:border-dp-gold hover:text-dp-gold transition-colors">
            {authors.vasily.bioLabel ?? 'Биография'}
          </a>
        )}
      </div>
    </div>

    <!-- Divider -->
    <div class="my-16 flex items-center gap-4">
      <div class="flex-1 h-px bg-dp-border"></div>
      <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
      <div class="flex-1 h-px bg-dp-border"></div>
    </div>

    <!-- Social media -->
    <div class="relative border border-dp-border max-w-2xl mx-auto px-10 py-8">
      <div class="absolute top-2 left-2 w-5 h-5 border-l border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute top-2 right-2 w-5 h-5 border-r border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 left-2 w-5 h-5 border-l border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 right-2 w-5 h-5 border-r border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="text-center mb-8">
        <h2 class="font-heading text-2xl font-semibold">Соцсети</h2>
        <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      </div>
      <div class="flex justify-center gap-6 flex-wrap">
        {links.socials.map((s: {label: string; url: string; icon: string}) => (
          <a href={s.url} title={s.label} aria-label={s.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
            <div class="w-12 h-12 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
              <Icon name={s.icon} />
            </div>
          </a>
        ))}
      </div>
      <p class="text-center font-accent italic text-dp-muted text-base mt-8">
        Связаться с нами{' '}
        <a href={links.contact.vk} class="text-dp-text hover:text-dp-gold transition-colors border-b border-dp-border hover:border-dp-gold">ВКонтакте</a>
        {' '}или{' '}
        <a href={links.contact.telegram} class="text-dp-text hover:text-dp-gold transition-colors border-b border-dp-border hover:border-dp-gold">Телеграм</a>
      </p>
    </div>

    <!-- Divider -->
    <div class="my-16 flex items-center gap-4">
      <div class="flex-1 h-px bg-dp-border"></div>
      <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
      <div class="flex-1 h-px bg-dp-border"></div>
    </div>

    <!-- Literary platforms -->
    <div class="relative border border-dp-border max-w-2xl mx-auto px-10 py-8">
      <div class="absolute top-2 left-2 w-5 h-5 border-l border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute top-2 right-2 w-5 h-5 border-r border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 left-2 w-5 h-5 border-l border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 right-2 w-5 h-5 border-r border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="text-center mb-8">
        <h2 class="font-heading text-2xl font-semibold">Литпорталы</h2>
        <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 max-w-2xl mx-auto">
        <div>
          <h3 class="font-heading text-base font-semibold pb-3 border-b border-dp-border text-dp-text text-center">Ксения Котова</h3>
          <div class="flex gap-3 mt-4 flex-wrap justify-center">
            {links.litportals.ksenia.map((p: {label: string; url: string}) => (
              <a href={p.url} aria-label={p.label} title={p.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
                <div class="w-10 h-10 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
                  <Icon name={p.label} />
                </div>
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-heading text-base font-semibold pb-3 border-b border-dp-border text-dp-text text-center">Василий Зеленков</h3>
          <div class="flex gap-3 mt-4 flex-wrap justify-center">
            {links.litportals.vasily.map((p: {label: string; url: string}) => (
              <a href={p.url} aria-label={p.label} title={p.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
                <div class="w-10 h-10 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
                  <Icon name={p.label} />
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="pb-12"></div>
  </div>
</BaseLayout>
