---
import BaseLayout from '../layouts/BaseLayout.astro';
import CoversGallery from '../components/CoversGallery.astro';
import Icon from '../components/Icon.astro';
import { getCollection } from 'astro:content';
import { readFileSync } from 'fs';
import { join } from 'path';
import matter from 'gray-matter';

const newsRaw = readFileSync(join(process.cwd(), 'src/data/news.md'), 'utf-8');
const { data: news } = matter(newsRaw) as { data: {
  visible: boolean;
  text?: string;
  links?: { label: string; url: string }[];
}};

// Книги из коллекции (только видимые в галерее)
const allBooks = await getCollection('books');
const visibleBooks = allBooks.filter(b => !b.data.series || (b.data.books && b.data.books.length > 0));
const orderedBooks = [...visibleBooks].sort((a, b) =>
  (a.data.displayOrder ?? 999) - (b.data.displayOrder ?? 999)
);
const covers = orderedBooks.map(b => ({
  slug: b.slug,
  title: b.data.title,
  src: `/images/${b.data.cover}`,
  description: b.data.shortDescription,
  marketplace: b.data.marketplace,
  links: b.data.links?.length ? b.data.links : (b.data.seriesLinks ?? []),
}));

// links.md
const linksRaw = readFileSync(join(process.cwd(), 'src/data/links.md'), 'utf-8');
const { data: links } = matter(linksRaw);

// telegram.md
const tgRaw = readFileSync(join(process.cwd(), 'src/data/telegram.md'), 'utf-8');
const { data: tg } = matter(tgRaw);
---
<BaseLayout title="Главная">
  <!-- Hero -->
  <section class="relative overflow-hidden py-8 md:py-12">
    <div class="absolute inset-0 bg-gradient-to-b from-dp-dark via-dp-dark/95 to-dp-dark/80"></div>
    <div class="absolute top-5 left-6 w-10 h-10 border-l-2 border-t-2 border-dp-gold/40 z-10"></div>
    <div class="absolute top-5 right-6 w-10 h-10 border-r-2 border-t-2 border-dp-gold/40 z-10"></div>
    <div class="absolute bottom-5 left-6 w-10 h-10 border-l-2 border-b-2 border-dp-gold/40 z-10"></div>
    <div class="absolute bottom-5 right-6 w-10 h-10 border-r-2 border-b-2 border-dp-gold/40 z-10"></div>
    <div class="relative z-10 max-w-5xl mx-auto px-6">
      <div class="grid grid-cols-1 xl:grid-cols-[200px_1fr_200px] items-center gap-0">
        <div class="hidden xl:block h-72 pointer-events-none overflow-hidden self-center"
          style="mask-image: linear-gradient(to right, transparent 0%, black 25%, black 60%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); mask-composite: intersect; -webkit-mask-image: linear-gradient(to right, transparent 0%, black 25%, black 60%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); -webkit-mask-composite: source-in;">
          <img src="/images/authors/kk.jpg" alt="Ксения Котова" class="w-full h-full object-cover object-[50%_8%] opacity-65" />
        </div>
        <div class="text-center px-6 xl:px-10">
          <p class="font-accent italic text-dp-gold/80 text-base mb-3 tracking-wide">Те, кто смотрят на небо, еще умеют мечтать</p>
          <h1 class="font-heading text-xl md:text-3xl font-bold text-parchment leading-tight mb-4">
            Соавторский дуэт:<br/>Ксения Котова,<br/>Василий Зеленков
          </h1>
          <div class="w-16 h-px bg-dp-gold mx-auto mb-4"></div>
          <p class="text-parchment/70 text-base leading-relaxed mb-7 max-w-xl mx-auto">
            Авторские миры, забытые легенды и латунные сердца, бьющиеся вопреки. Наши романы — ностальгия по альтернативному прошлому и мечта о неслучившемся будущем с осязаемой красотой безумных устройств.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 justify-center">
            <a href="/books" class="px-7 py-2.5 bg-dp-gold text-dp-dark font-body text-sm tracking-widest uppercase hover:bg-dp-copper transition-colors">Книги</a>
            <a href="/about" class="px-7 py-2.5 border border-dp-gold/50 text-parchment/80 text-sm tracking-widest uppercase hover:border-dp-gold hover:text-parchment transition-colors">Об авторах</a>
          </div>
        </div>
        <div class="hidden xl:block h-72 pointer-events-none overflow-hidden self-center"
          style="mask-image: linear-gradient(to left, transparent 0%, black 25%, black 60%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); mask-composite: intersect; -webkit-mask-image: linear-gradient(to left, transparent 0%, black 25%, black 60%, transparent 100%), linear-gradient(to bottom, transparent 0%, black 15%, black 85%, transparent 100%); -webkit-mask-composite: source-in;">
          <img src="/images/authors/vz.jpg" alt="Василий Зеленков" class="w-full h-full object-cover object-[50%_8%] opacity-65" />
        </div>
      </div>
    </div>
  </section>

  <!-- News banner -->
  {news.visible && news.text && (
    <div class="max-w-5xl mx-auto px-6 pt-6">
      <div class="mx-[30px] flex flex-wrap items-baseline gap-3 py-3 border border-dp-gold/30 bg-dp-gold/5 text-dp-text leading-relaxed px-6">
        <span class="text-[9px] tracking-widest uppercase text-dp-gold shrink-0">Новости</span>
        <span class="font-accent italic text-base">{news.text}</span>
        {news.links && news.links.map(link => (
          <a href={link.url} target="_blank" rel="noopener noreferrer"
            class="text-[10px] font-body tracking-widest px-1.5 py-0.5 border border-dp-gold/50 text-dp-gold hover:border-dp-gold hover:text-dp-text transition-colors shrink-0">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Covers Gallery -->
  <section class="max-w-5xl mx-auto px-6 pt-8 pb-2">
    <div class="text-center mb-4">
      <h2 class="font-heading text-3xl font-semibold">Книги</h2>
      <div class="w-12 h-px bg-dp-gold mx-auto mt-4 mb-4"></div>
      <p class="font-accent italic text-dp-muted text-base">Каждая история — вход в потрясающий авторский мир</p>
    </div>
    <CoversGallery covers={covers} />
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-4">
      <div class="flex-1 h-px bg-dp-border"></div>
      <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
      <div class="flex-1 h-px bg-dp-border"></div>
    </div>
  </div>

  <!-- Literary platforms -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <div class="relative border border-dp-border max-w-2xl mx-auto px-10 py-8">
      <div class="absolute top-2 left-2 w-5 h-5 border-l border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute top-2 right-2 w-5 h-5 border-r border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 left-2 w-5 h-5 border-l border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 right-2 w-5 h-5 border-r border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="text-center mb-8">
        <h2 class="font-heading text-2xl font-semibold">Литпорталы</h2>
        <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
        <div>
          <h3 class="font-heading text-base font-semibold pb-3 border-b border-dp-border text-dp-text text-center">Ксения Котова</h3>
          <div class="flex gap-3 mt-4 flex-wrap justify-center">
            {links.litportals.ksenia.map((p: {label: string; url: string}) => (
              <a href={p.url} aria-label={p.label} title={p.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
                <div class="w-10 h-10 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
                  <Icon name={p.label} />
                </div>
              </a>
            ))}
          </div>
        </div>
        <div>
          <h3 class="font-heading text-base font-semibold pb-3 border-b border-dp-border text-dp-text text-center">Василий Зеленков</h3>
          <div class="flex gap-3 mt-4 flex-wrap justify-center">
            {links.litportals.vasily.map((p: {label: string; url: string}) => (
              <a href={p.url} aria-label={p.label} title={p.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
                <div class="w-10 h-10 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
                  <Icon name={p.label} />
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-4">
      <div class="flex-1 h-px bg-dp-border"></div>
      <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
      <div class="flex-1 h-px bg-dp-border"></div>
    </div>
  </div>

  <!-- Social media -->
  <section class="max-w-5xl mx-auto px-6 py-12">
    <div class="relative border border-dp-border max-w-2xl mx-auto px-10 py-8">
      <div class="absolute top-2 left-2 w-5 h-5 border-l border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute top-2 right-2 w-5 h-5 border-r border-t border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 left-2 w-5 h-5 border-l border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="absolute bottom-2 right-2 w-5 h-5 border-r border-b border-dp-gold/50 pointer-events-none"></div>
      <div class="text-center mb-8">
        <h2 class="font-heading text-2xl font-semibold">Соцсети</h2>
        <div class="w-12 h-px bg-dp-gold mx-auto mt-4"></div>
      </div>
      <div class="flex justify-center gap-6 flex-wrap">
        {links.socials.map((s: {label: string; url: string; icon: string}) => (
          <a href={s.url} title={s.label} aria-label={s.label} class="group text-dp-muted hover:text-dp-gold transition-colors">
            <div class="w-12 h-12 border border-dp-border group-hover:border-dp-gold transition-colors flex items-center justify-center">
              <Icon name={s.icon} />
            </div>
          </a>
        ))}
      </div>
      <p class="text-center font-accent italic text-dp-muted text-base mt-8">
        Связаться с нами{' '}
        <a href={links.contact.vk} class="text-dp-text hover:text-dp-gold transition-colors border-b border-dp-border hover:border-dp-gold">ВКонтакте</a>
        {' '}или{' '}
        <a href={links.contact.telegram} class="text-dp-text hover:text-dp-gold transition-colors border-b border-dp-border hover:border-dp-gold">Телеграм</a>
      </p>
    </div>
  </section>

  <!-- Divider -->
  <div class="max-w-5xl mx-auto px-6">
    <div class="flex items-center gap-4">
      <div class="flex-1 h-px bg-dp-border"></div>
      <div class="w-2 h-2 rotate-45 bg-dp-gold/50"></div>
      <div class="flex-1 h-px bg-dp-border"></div>
    </div>
  </div>

  <!-- Telegram feed -->
  <section class="max-w-5xl mx-auto px-6 pt-8 pb-4">
    <div class="mb-12">
      <h2 class="font-heading text-3xl font-semibold">Последние новости</h2>
      <div class="w-12 h-px bg-dp-gold mt-4"></div>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="border border-dp-border p-6 flex flex-col gap-3">
        <p class="text-[10px] tracking-widest uppercase text-dp-muted">{tg.posts.digest.label}</p>
        <div class="flex-1">
          <script is:inline async src="https://telegram.org/js/telegram-widget.js?22"
            data-telegram-post={tg.posts.digest.postId}
            data-width="100%"
            data-userpic="false"
            data-color="C9A84C"></script>
        </div>
      </div>
      <div class="border border-dp-border p-6 flex flex-col gap-3">
        <p class="text-[10px] tracking-widest uppercase text-dp-muted">{tg.posts.current.label}</p>
        <div class="flex-1 text-dp-muted font-accent italic leading-relaxed">Здесь будет виджет актуального поста</div>
      </div>
      <div class="border border-dp-border p-6 flex flex-col gap-3">
        <p class="text-[10px] tracking-widest uppercase text-dp-muted">{tg.posts.intro.label}</p>
        <div class="flex-1 text-dp-muted font-accent italic leading-relaxed">Здесь будет виджет вводного поста</div>
      </div>
    </div>
  </section>
</BaseLayout>
